# ========================
# ACCOUNT SETTINGS
# ========================
ACCOUNT_BALANCE=1000.0
RISK_PER_TRADE=0.01          # 1% risk per trade
MAX_TRADES_PER_DAY=3
DAILY_LOSS_LIMIT=0.03        # 3% daily max loss
LOSS_COOLDOWN_BARS=12        # skip 12×5m=1 hour after a loss to prevent re-entering same failing zone
ZONE_COOLDOWN_HOURS=0.0      # block re-entry into same price zone for N hours after any trade closes; 0.0 = disabled
LOT_TIER_CAPITAL=1000.0      # $1000 balance = 0.01 lot, $2000 = 0.02 lot, etc.
MIN_LOT_SIZE=0.01            # minimum lot (also the partial-TP split threshold)
MAX_RISK_TOLERANCE_MULT=2.0  # reject if actual $ loss at final lot > balance×risk%×this; 2.0 = max $20 on $1000 (needed for wider SL to survive stop hunts)
FIXED_LOT_SIZE=0.0           # 0.0 = dynamic risk-based sizing; set to e.g. 0.01 to always trade that exact lot regardless of balance or SL

# ========================
# INSTRUMENT
# ========================
SYMBOL=XAUUSD
POINT_VALUE=0.01             # tick value for gold (1 cent per tick)
CONTRACT_SIZE=100            # gold standard lot size (100 oz)

# ========================
# TIMEFRAMES
# ========================
HTF_TIMEFRAMES=4H,1H
MTF_TIMEFRAME=15m
LTF_TIMEFRAME=5m

# ========================
# FILTERS
# ========================
ATR_THRESHOLD=1.0            # minimum ATR for gold (in USD)
SPREAD_LIMIT=0.5             # maximum spread allowed for gold (in USD)
MIN_RR=2.0                   # minimum reward:risk ratio (2.5 was rejecting 237 trades in trending markets)

# ========================
# SESSIONS (UTC hours)
# ========================
SESSION_ASIAN_START=0            # Tokyo/Sydney open (gold active 00:00–05:00 UTC)
SESSION_ASIAN_END=5
SESSION_LONDON_START=7
SESSION_LONDON_END=16
SESSION_NEWYORK_START=12
SESSION_NEWYORK_END=21

# ========================
# SCORING THRESHOLDS
# ========================
MIN_SCORE_EXECUTE=70            # minimum score to execute a trade (raised from 65 after 8/12 losses had score <70)
MIN_SCORE_OPTIONAL=50           # score range for "optional" label (not executed)

# ========================
# AI MODEL
# ========================
AI_PROBABILITY_THRESHOLD=0.65
AI_MIN_SAMPLES_TO_TRAIN=50

# ========================
# SELF-LEARNING
# ========================
MIN_TRADES_BEFORE_ADAPT=20
MAX_DRAWDOWN_PROTECTION=0.15  # 15% max drawdown before halt
LEARNING_ENABLED=true

# ========================
# PATHS
# ========================
DATA_DIR=data
LOGS_DIR=logs
MODELS_DIR=ai/models

# ========================
# ORDER BLOCK DETECTION
# ========================
OB_LOOKBACK=50                 # bars to scan for order blocks
OB_IMPULSE_THRESHOLD_HTF=1.5   # HTF (4H/1H): move must be N× avg candle range to qualify as impulse
OB_IMPULSE_THRESHOLD_MTF=0.7   # MTF (15m): reduced from 1.0 — catches more OBs on current volatile market
OB_IMPULSE_LOOKAHEAD=10        # max bars ahead to confirm the impulse move
OB_ZONE_MAX_AGE_BARS=50        # discard 15m zones older than this many bars (~12.5 h); was 30

# ========================
# SWING DETECTION
# ========================
SWING_LOOKBACK_HTF=5           # bars each side for 4H/1H swing high/low
SWING_LOOKBACK_MTF=3           # bars each side for 15m swing high/low
SWING_LOOKBACK_LTF=2           # bars each side for 5m CHoCH detection

# ========================
# LIQUIDITY DETECTION
# ========================
LIQUIDITY_EQ_TOLERANCE=0.20    # max price diff to count as equal high/low (gold: ~$0.20)
LIQUIDITY_LOOKBACK=20          # bars to scan for equal highs/lows

# ========================
# ATR
# ========================
ATR_PERIOD=14                  # Wilder ATR period

# ========================
# FAIR VALUE GAP
# ========================
FVG_MIN_SIZE=0.0               # minimum FVG size in price units (0 = accept all)

# ========================
# BACKTEST REALISM
# ========================
# These make simulated results match live execution.
# Without them, backtest is too optimistic (zero-cost fantasy).
BACKTEST_SPREAD=0.30           # spread per trade in price units (gold: ~$0.30 = 3 pips)
BACKTEST_COMMISSION=0.0        # commission per lot in $ per side (ECN: ~3.50, spread-only: 0)
BACKTEST_SLIPPAGE=0.10         # entry fill slippage in price units (gold: ~$0.10)

# ========================
# TRADE MANAGEMENT
# ========================
SL_ATR_BUFFER=0.5              # ATR multiplier beyond zone edge for SL — 0.3 too tight (stop hunts), 1.0 too wide (zero_lot on high-ATR bars); 0.5 is middle ground
TRAILING_SL_ATR_MULT=3.0       # ATR multiplier for trailing stop distance (was 1.5 — too tight, stopped out winners early)
PARTIAL_TP_PCT=0.5             # fraction of position closed at TP1 (0.5 = 50%)
USE_BREAKEVEN=true             # true = move SL to entry after trigger hit (safe, protects profit)
                               # false = keep original structure SL for full trade (riskier but lets winners run to TP2)
BREAKEVEN_TRIGGER_RR=1.0       # at what RR multiple to move SL to break-even (USE_BREAKEVEN must be true)
                               # 1.0 = trigger at TP1 (1:1 RR) — RECOMMENDED: BE moves same time as partial TP
                               # 1.5 = trigger halfway between TP1 and TP2 — risk: partial TP fires but BE doesn't, price reverses to full SL
                               # 2.0 = trigger at TP2 — only protect after full target reached
BREAKEVEN_BUFFER_PIPS=100.0    # pips above/below entry when moving SL to BE (× POINT_VALUE); 100 × $0.01 = $1.00 buffer for gold
                               # only used when USE_BREAKEVEN=true
ATR_TRAILING_BARS=50           # how many recent 5m bars to use for ATR in trailing SL

# ========================
# SIGNAL CONFIRMATION
# ========================
CANDLE_WICK_RATIO=2.0          # hammer/shooting star: wick must be N× the body
CHOCH_BREAKS_TO_CHECK=5        # last N structure breaks scanned for CHoCH confirmation
MAX_SL_ATR_MULT=5.0            # reject signal if zone-based SL > N× ATR (prevents zero-lot trades on wide OBs)
MIN_ZONE_QUALITY=0.4           # minimum zone quality (0–1); 0.4=plain OB accepted, 0.3=FVG-only rejected
                               # 0.4=OB only, 0.5=OB+internal_bos, 0.7=OB+FVG, 0.9=OB+FVG+confluence

# ========================
# BACKTEST METRICS
# ========================
SHARPE_BARS_PER_DAY=78         # 5m bars in a trading day (6.5h × 12 = 78); change if using different LTF
RISK_FREE_RATE=0.0             # annualised risk-free rate for Sharpe (e.g. 0.05 for 5%)

# ========================
# BACKTEST WARMUP BARS
# ========================
HTF_WARMUP_BARS=200            # minimum 4H bars needed before first analysis
MTF_WARMUP_BARS=100            # minimum 15m bars needed before first analysis
LTF_WARMUP_BARS=60             # minimum 5m bars needed before first analysis

# ========================
# SWEEP SCORING THRESHOLDS
# ========================
SWEEP_HIGH_PIPS=10.0           # sweep size for max score (20 pts)
SWEEP_MED_PIPS=5.0             # sweep size for medium score (15 pts)
SWEEP_LOW_PIPS=2.0             # sweep size for low score (10 pts)
SWEEP_MIN_PIPS=0.5             # sweep size for minimal score (5 pts)

# ========================
# CONDITION FILTERS
# Set false to bypass a condition (for testing which filters are working)
# ========================

# HTF layer
# Test evidence: FILTER_HTF_CONFLUENCE=true reduced trades from 36→17, WR from 50%→23.5%,
# PF from 1.75→0.65. The bias_confirmed check is too strict — disable until HTF logic improves.
FILTER_HTF_CONFLUENCE=false

# MTF layer
# FILTER_PREMIUM_DISCOUNT=true consistently improved results: PF 1.75→2.12, DD 7.2%→4.0%
# Only disable for synthetic/sample CSV data where OBs fall outside swing range
FILTER_PREMIUM_DISCOUNT=true

# LTF layer
FILTER_SESSION=true            # only trade during London/NY sessions (disable for CSV backtesting)
FILTER_SPREAD=false            # disable for backtesting CSV (no live spread data)
FILTER_PRICE_IN_ZONE=true      # current price must be inside the refined zone
FILTER_ZONE_ENTRY_HALF=false   # too aggressive — price_not_at_*_half kills 1500+ valid entries; SMC OBs are often entered from any price in zone
FILTER_LIQUIDITY_SWEEP=false   # enable with real tick data; synthetic CSV rarely has wick-sweeps
FILTER_CHOCH=false             # CHoCH fires early in SMC (before OB retracement); by entry time it's no longer in recent 5 breaks → 900+ false rejections
FILTER_CANDLE_CONFIRMATION=false # 5m engulfing too rare in volatile gold (1195 rejections/60d); candle confirmation already adds +5pts to score
FILTER_ENTRY_BAR_CLOSE=false # require entry bar close in trade direction (lower 35% for sell, upper 35% for buy); catches immediate-reversal entries
ENTRY_BAR_CLOSE_PCT=0.35     # close must be in top/bottom N% of bar range (0.35 = 35%)
FILTER_MIN_RR=true             # block trades below MIN_RR

# Engine layer
FILTER_SCORE=true              # block trades with score < MIN_SCORE_EXECUTE
FILTER_AI=false                # AI model needs real trade history to train — disable until then
FILTER_RISK_MANAGEMENT=true    # enforce daily loss limit and max trades per day

# ========================
# BROKER — MT5 / EXNESS
# ========================
# Your Exness MT5 account number (shown in Exness Personal Area)
MT5_LOGIN=

# Your MT5 password
MT5_PASSWORD=

# Demo  : Exness-MT5Trial
# Live  : Exness-MT5Real  (or Exness-MT5Real2 / Exness-MT5Real3 — shown in MT5 terminal)
MT5_SERVER=Exness-MT5Trial

# Leave blank to auto-detect the MT5 terminal.
# Set to full path if auto-detect fails, e.g.:
#   C:\Program Files\MetaTrader 5\terminal64.exe
MT5_TERMINAL_PATH=

# Symbol name exactly as it appears in MT5 Market Watch.
# Exness standard/pro accounts: XAUUSD
# Some Exness cent accounts use: XAUUSDc
MT5_SYMBOL=XAUUSD

# Unique magic number — identifies this bot's orders (avoid conflicts with manual trades).
# Change if you run multiple bots on the same account.
MT5_MAGIC=20250101

# Historical 5m bars fetched at startup to prime the strategy (≈35 days).
# Increase if HTF analysis feels shallow on first run.
MT5_WARMUP_BARS=10000
